{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "darkMode": { "type": "boolean" },
        "notificationsEnabled": { "type": "boolean" },
        "profilePicture": { "type": "string" }
      },
      "required": ["uid", "username", "createdAt"]
    },
    "Plant": {
      "title": "Plant",
      "description": "A plant belonging to a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "health": { "type": "number" },
        "image": { "type": "string" },
        "location": { "type": "string" },
        "wateringFrequency": { "type": "number" },
        "lastWatered": { "type": "string", "format": "date-time" },
        "nextWater": { "type": "string", "format": "date-time" },
        "sunlight": { "type": "string" },
        "temperature": { "type": "string" },
        "humidity": { "type": "string" },
        "history": {
          "type": "string"
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "type", "wateringFrequency", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/plants/{plantId}": {
      "schema": { "$ref": "#/entities/Plant" },
      "description": "User plants"
    }
  }
}
